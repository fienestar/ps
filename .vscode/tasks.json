{
    "version": "2.0.0",
    "runner": "terminal",
    "type": "shell",
    "echoCommand": true,
    "presentation" : { "reveal": "always" },
    "tasks": [
        {
            "label": "build and run cpp",
            "command": "g++",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}\\Release\\${fileBasenameNoExtension}.exe",
                "-std=c++17",
                "-O4",
                "-DLOCAL(x)=(x)",
                "-DOUTPUT_TO_FILE=freopen(\\\"$output.txt\\\",\\\"w\\\",stdout)",
                "-DINPUT_FROM_FILE=freopen(\\\"input\\\\${fileBasenameNoExtension}.txt\\\",\\\"r\\\",stdin)"
            ],
            "group":"test",
            "problemMatcher": {
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "exec",
            "command": "cd",
            "group":{
                "kind": "test",
                "isDefault": true
            },
            "args": [
                "${fileDirname}",
                "&&",
                "Release\\${fileBasenameNoExtension}.exe"
            ],
            "dependsOn": [
                "build and run cpp"
            ]
        }
    ]
}